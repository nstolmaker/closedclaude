[Unit]
Description=MCP Proxy (mam, kb, ads-manager)
After=network.target

[Service]
Type=simple
User=nstolmaker
ExecStart=/home/nstolmaker/.local/bin/mcp-proxy \
    --named-server-config /home/nstolmaker/dev/closedclaude/mcp-servers.json \
    --port 4001 \
    --host 127.0.0.1
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
